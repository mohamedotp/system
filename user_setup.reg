Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Software\Classes\aoi-open]
@="URL:aoi-open Protocol"
"URL Protocol"=""

[HKEY_CURRENT_USER\Software\Classes\aoi-open\shell\open\command]
@="powershell.exe -NoExit -ExecutionPolicy Bypass -Command \"& { $raw = $args[0]; Write-Host '--- AOI Protocol Server Redirect Mode ---' -ForegroundColor Cyan; Write-Host '1. Raw Input:' -ForegroundColor Yellow; Write-Host $raw; try { $u=[uri]::UnescapeDataString($raw) -replace '^aoi-open[:/]*',''; $u=$u.Replace('/','\\\\'); $u=$u.Trim().TrimEnd('\\\\').Trim('\\\\\\\"'); if($u -like 'C:\\\\Archives*'){ $u = $u -replace '^C:\\\\Archives', '\\\\\\\\192.168.13.12\\\\homes' }; Write-Host '`n2. Final Path:' -ForegroundColor Yellow; Write-Host $u; if((Test-Path -LiteralPath $u) -or ($u.ToLower().EndsWith('.xlsx')) -or ($u.ToLower().EndsWith('.xls'))){ Write-Host '`n3. Status: SUCCESS' -ForegroundColor Green; start explorer \\\"$u\\\"; sleep 2; exit } else { Write-Host '`n3. Status: ERROR - Path Not Found!' -ForegroundColor Red; Write-Host \\\"Target: $u\\\" } } catch { Write-Host '`nERROR: ' $_.Exception.Message }; Write-Host '`n--- Press any key to close ---'; [void]$Host.UI.RawUI.ReadKey('NoEcho,IncludeKeyDown') }\" -- \"%1\""
 